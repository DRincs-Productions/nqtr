{
  "compilerOptions": {
    "target": "ESNext",
    "experimentalDecorators": true,
    "module": "esnext",
    "paths": {
      "@/*": ["./src/*"],
      "@drincs/nqtr/registries": ["./src/registries/index.ts"],
      "@drincs/nqtr/handlers": ["./src/handlers/index.ts"]
    },
    "resolveJsonModule": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"]
}
